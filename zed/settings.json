// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "tool_permissions": {
      "tools": {
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://github\\.com"
            }
          ]
        }
      }
    },
    "default_profile": "write",
    "profiles": {
      "minimal": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "gpt-5.5",
          "enable_thinking": true,
          "effort": "high"
        },
        "name": "minimal",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
      "enable_thinking": true,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Claude Code Inspired Dark",
  },
  "auto_install_extensions": {
    "claude-code-inspired-dark": true,
    "colored-zed-icons-theme": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "html": true,
    "git-firefly": true,
    "github-actions": true,
    "log": true,
    "make": true,
    "nginx": true,
    "ssh-config": true,
    "sql": true,
    "toml": true,
    "xml": true,
  },
  "context_servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"],
      "env": {},
    },
  },
}
